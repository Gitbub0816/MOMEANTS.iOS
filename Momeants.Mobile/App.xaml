<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Momeants.Mobile"
             xmlns:conv="clr-namespace:Momeants.Mobile.Converters"
             x:Class="Momeants.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:InvertBoolConverter x:Key="InvertBoolConverter" />
            <conv:IsNotNullConverter x:Key="IsNotNullConverter" />
            <conv:IsNullConverter x:Key="IsNullConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
