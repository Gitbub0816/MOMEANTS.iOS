<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Momeants.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:auth="clr-namespace:Momeants.Mobile.Views.Auth"
    xmlns:feed="clr-namespace:Momeants.Mobile.Views.Feed"
    xmlns:profile="clr-namespace:Momeants.Mobile.Views.Profile"
    xmlns:capture="clr-namespace:Momeants.Mobile.Views.Capture"
    Shell.NavBarIsVisible="False"
    FlyoutBehavior="Disabled">

    <!-- Auth flow (not in tabs) -->
    <ShellContent Route="WelcomePage" ContentTemplate="{DataTemplate auth:WelcomePage}" Shell.NavBarIsVisible="False" />

    <!-- Main tab bar -->
    <TabBar Route="main">
        <Tab Title="Feed" Icon="tab_feed.png">
            <ShellContent Route="FeedPage" ContentTemplate="{DataTemplate feed:FeedPage}" />
        </Tab>
        <Tab Title="Profile" Icon="tab_profile.png">
            <ShellContent Route="ProfilePage" ContentTemplate="{DataTemplate profile:ProfilePage}" />
        </Tab>
    </TabBar>
</Shell>
