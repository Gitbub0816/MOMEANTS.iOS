<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Momeants.Mobile.Views.Auth.VerifyCodePage"
             Title="Verify"
             BackgroundColor="#000000">

    <Grid RowDefinitions="Auto, *, Auto" Padding="24">
        <StackLayout Grid.Row="0" Margin="0,60,0,40">
            <Label Text="Enter the code" FontSize="24" FontAttributes="Bold" TextColor="White" />
            <Label Text="{Binding Identifier, StringFormat='Sent to {0}'}" TextColor="#888888" FontSize="14" />
        </StackLayout>

        <StackLayout Grid.Row="1" Spacing="16">
            <Entry Placeholder="6-digit code"
                   PlaceholderColor="#888888"
                   TextColor="White"
                   BackgroundColor="#1A1A1A"
                   Text="{Binding Code}"
                   Keyboard="Numeric"
                   MaxLength="6"
                   HeightRequest="52" />
            <Label Text="{Binding ErrorMessage}" TextColor="#FF4444" IsVisible="{Binding HasError}" />
            <Button Text="Resend code" Command="{Binding ResendCommand}"
                    BackgroundColor="Transparent" TextColor="#888888" />
        </StackLayout>

        <Button Grid.Row="2" Text="Verify" Command="{Binding VerifyCommand}"
                BackgroundColor="White" TextColor="Black"
                CornerRadius="12" HeightRequest="52"
                Margin="0,0,0,40" />
    </Grid>
</ContentPage>
