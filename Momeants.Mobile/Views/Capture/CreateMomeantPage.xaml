<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Momeants.Mobile.Views.Capture.CreateMomeantPage"
             Title="New Momeant"
             BackgroundColor="#000000">

    <ScrollView>
        <StackLayout Padding="24" Spacing="16">
            <!-- Photo picker -->
            <Frame BackgroundColor="#1A1A1A" CornerRadius="12" HeightRequest="300" Padding="0"
                   HasShadow="False">
                <Grid>
                    <Image Source="{Binding SelectedImage}" Aspect="AspectFill" IsVisible="{Binding SelectedImage, Converter={StaticResource IsNotNullConverter}}" />
                    <Button Text="Tap to choose photo" Command="{Binding PickPhotoCommand}"
                            BackgroundColor="Transparent" TextColor="#888888"
                            IsVisible="{Binding SelectedImage, Converter={StaticResource IsNullConverter}}" />
                </Grid>
            </Frame>

            <!-- Caption -->
            <Editor Placeholder="Add a caption..." PlaceholderColor="#888888"
                    TextColor="White" BackgroundColor="#1A1A1A"
                    Text="{Binding Caption}"
                    AutoSize="TextChanges"
                    MinimumHeightRequest="80" />

            <!-- Audience -->
            <Picker Title="Who can see this?" TextColor="White" TitleColor="#888888"
                    BackgroundColor="#1A1A1A"
                    SelectedItem="{Binding AudienceType}">
                <Picker.Items>
                    <x:String>friends</x:String>
                    <x:String>close_friends</x:String>
                    <x:String>private</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="{Binding ErrorMessage}" TextColor="#FF4444" IsVisible="{Binding HasError}" />

            <Button Text="Post Momeant" Command="{Binding PostCommand}"
                    BackgroundColor="White" TextColor="Black"
                    CornerRadius="12" HeightRequest="52" />

            <Button Text="Cancel" Command="{Binding CancelCommand}"
                    BackgroundColor="Transparent" TextColor="#888888" />
        </StackLayout>
    </ScrollView>
</ContentPage>
