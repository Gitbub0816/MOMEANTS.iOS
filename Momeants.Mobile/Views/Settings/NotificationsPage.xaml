<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Momeants.Mobile.Views.Settings.NotificationsPage"
             Title="Notifications"
             BackgroundColor="#000000">
    <StackLayout Padding="24">
        <Label Text="Notifications" TextColor="White" FontSize="24" FontAttributes="Bold" Margin="0,0,0,16" />
        <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" />
        <Button Text="Mark all read" Command="{Binding MarkAllReadCommand}"
                BackgroundColor="#1A1A1A" TextColor="White" CornerRadius="8" />
    </StackLayout>
</ContentPage>
